<Window x:Class="LazyWpf.Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LazyWpf.Test"
        xmlns:lazy="clr-namespace:LazyWpf;assembly=LazyWpf"
        x:Name="root"
        mc:Ignorable="d"
        ThemeMode="Light"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <StackPanel Orientation="Horizontal">
            <lazy:Button Margin="5" Text="Click to swtich" Click="Button_Click" Height="40" IsAccented="True"/>
            <lazy:Button Margin="5" Icon="&#xE701;" Click="Button_Click" Height="40"/>
            <lazy:Button Margin="5" Icon="&#xE709;" Text="Take off" Click="Button_Click" Height="40"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <lazy:Button Margin="5" Icon="&#xE737;" Text="Show MsgBox" Click="Button_Click_1" Height="40"/>
            <TextBlock Margin="5" Text="{Binding ElementName=root, Path=MsgBoxResult, Mode=TwoWay}" VerticalAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</Window>
