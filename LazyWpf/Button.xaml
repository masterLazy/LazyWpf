<UserControl x:Class="LazyWpf.Button"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LazyWpf"
             mc:Ignorable="d" 
             x:Name="root" Loaded="root_Loaded">
    <Button Height="{Binding ElementName=root, Path=Height}" d:Height="40"
            Width="{Binding ElementName=root, Path=Width}"
            x:Name="btn">
        <StackPanel Orientation="Horizontal">
            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="{Binding ElementName=root, Path=Icon}"
                       VerticalAlignment="Center" x:Name="TbIcon"/>
            <TextBlock Text="{Binding ElementName=root, Path=Text}"/>
        </StackPanel>
    </Button>
</UserControl>
