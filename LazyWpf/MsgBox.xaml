<Window x:Class="LazyWpf.MsgBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LazyWpf"
        xmlns:loc="clr-namespace:LazyWpf.res"
        x:Name="root"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        MinWidth="400" MaxWidth="650"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow"
        ThemeMode="Light"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        RenderOptions.BitmapScalingMode="HighQuality"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/LazyWpf;component/res/Dict.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Window.Background>
        <StaticResource ResourceKey="BhDefault"/>
    </Window.Background>
    <DockPanel>
        <!--底栏-->
        <DockPanel DockPanel.Dock="Bottom" Background="{StaticResource BhGray}">
            <DockPanel DockPanel.Dock="Right" Margin="10" LastChildFill="False">
                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnCancel" Icon="&#xE711;" Text="{x:Static loc:Lang.Mb_Cancel}" />
                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnOK" Icon="&#xE8FB;" Text="{x:Static loc:Lang.Mb_OK}" />

                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnIgnore" Icon="&#xECE4;" Text="{x:Static loc:Lang.Mb_Ignore}" />
                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnContinue" Icon="&#xE72A;" Text="{x:Static loc:Lang.Mb_Continue}" />
                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnRetry" Icon="&#xE72C;" Text="{x:Static loc:Lang.Mb_Retry}" />
                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnAbort" Icon="&#xE711;" Text="{x:Static loc:Lang.Mb_Abort}" />

                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnNo" Icon="&#xE711;" Text="{x:Static loc:Lang.Mb_No}" />
                <local:Button DockPanel.Dock="Right" Margin="5" Height="40" Click="BtnCancel_Click"
                          x:Name="BtnYes" Icon="&#xE8FB;" Text="{x:Static loc:Lang.Mb_Yes}" />
            </DockPanel>
        </DockPanel>
        <Separator DockPanel.Dock="Bottom" BorderBrush="{StaticResource BhBorder}"/>
        <!--主体-->
        <DockPanel>
            <TextBlock DockPanel.Dock="Left" Margin="40 50" FontFamily="{StaticResource SymbolThemeFontFamily}" 
                       FontSize="45" x:Name="MbIcon"/>
            <DockPanel>
                <TextBlock Margin="0 40 30 10" FontSize="20" FontWeight="Bold" DockPanel.Dock="Top"
                           Text="{Binding ElementName=root, Path=Title}"/>
                <TextBlock Margin="0 10 30 40" TextWrapping="Wrap"
                           FontSize="14" x:Name="MbText"/>
            </DockPanel>
        </DockPanel>
    </DockPanel>
</Window>
